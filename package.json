{
  "name": "uaip",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Edge-native LLM gateway + personal portal on Cloudflare Workers (zero framework, zero runtime deps, D1 only).",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json",
    "migrate:local": "wrangler d1 migrations apply ipua-logs --local",
    "migrate:remote": "wrangler d1 migrations apply ipua-logs --remote",
    "seed": "node tools/seed-local.mjs",
    "seed:e2e": "node tools/seed-e2e.mjs",
    "e2e": "playwright test",
    "apidoc": "node tools/build-apidoc.mjs",
    "openapi": "node tools/build-openapi.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "checks": "npm run lint && npm run typecheck && npm run test",
    "deploy": "npm run apidoc && npm run openapi && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.12",
    "@cloudflare/workers-types": "^4.20251011.0",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "~3.2.0",
    "wrangler": "~4.44.0",
    "yaml": "^2.9.0"
  }
}
